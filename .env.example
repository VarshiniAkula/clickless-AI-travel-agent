# ClickLess AI — Environment Variables

# Supabase (optional — app works in demo-only mode without these)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini (primary LLM — free tier, get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# OpenRouter (fallback LLM — falls back to deterministic template summary)
OPENROUTER_API_KEY=sk-or-...

# OpenWeatherMap (optional — demo uses seeded weather data)
OPENWEATHER_API_KEY=your-key
